@model List<RegistrationList.Data.IncomeMaster>
@{
    ViewBag.Title = "Income";
    Layout = null;
}
<script src="~/Scripts/jquery-3.7.0.min.js"></script>
<script src="~/Scripts/Income.js"></script>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Income · eSankalp Enterprise Portal</title>
    <link rel="icon" href="../assets/images/esankalp-logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/Content/assets/css/style.css">
    <link rel="stylesheet" href="~/Content/assets/css/dashboard.css">
    <link rel="stylesheet" href="~/Content/assets/css/responsive.css">

</head>
<body>
    <div id="sidebarBackdrop" class="sidebar-backdrop"></div>
    <div class="app">
        <aside class="sidebar scroll-soft">
            <div class="brand">
                <img src="~/Content/assets/images/hero-logo.png" alt="eSankalp">
                <div>
                    <div class="name">eSankalp</div>
                    <div class="tag">Enterprise Portal</div>
                </div>
            </div>
            <div class="section-label">Main</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Dashboard")"><i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span></a>
            <div class="section-label">Manage</div>
            <a class="nav-link-es" href="@Url.Action("Index", "RegistrationList")"><i class="bi bi-people-fill"></i><span>Registration List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationForm")"><i class="bi bi-pencil-square"></i><span>Application Form</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationList")"><i class="bi bi-list-check"></i><span>Application List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientAdd")"><i class="bi bi-person-plus-fill"></i><span>Client Add</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientList")"><i class="bi bi-briefcase-fill"></i><span>Client List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ContactList")"><i class="bi bi-envelope-fill"></i><span>Contact List</span></a>
            <div class="section-label">Finance</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Income")"><i class="bi bi-graph-up-arrow"></i><span>Income</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Expenses")"><i class="bi bi-graph-down-arrow"></i><span>Expenses</span></a>
            <div class="section-label">Content</div>
            <a class="nav-link-es" href="@Url.Action("Index", "AddProduct")"><i class="bi bi-box-seam"></i><span>Add Product</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Portfolio")"><i class="bi bi-images"></i><span>Add Portfolio</span></a>
            <a class="nav-link-es active" href="@Url.Action("Index", "JobApplication")"><i class="bi bi-person-badge"></i><span>Job Application</span></a>
            <div class="mt-auto pt-3">
                <a href="@Url.Action("Logout","Account")"
                   class="btn btn-outline-soft w-100">
                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                </a>
            </div>
        </aside>
        <main class="main">
            <header class="topbar">
                <div class="left">
                    <button id="sidebarToggle" class="icon-btn d-lg-none"><i class="bi bi-list"></i></button>
                    <div>
                        <div class="page-title">Income</div>
                        <div class="page-sub">Thinking Beyond Your Imagination</div>
                    </div>
                </div>
                <div class="d-none d-md-flex search hide-mobile">
                    <i class="bi bi-search text-muted"></i>
                    <input type="text" placeholder="Search anything...">
                </div>
                <div class="right">
                    <button class="icon-btn" title="Notifications"><i class="bi bi-bell"></i></button>
                    <button class="icon-btn" title="Settings"><i class="bi bi-gear"></i></button>
                    <div class="avatar" title="Profile"><span id="userName">A</span></div>
                </div>
            </header>
            <section class="content">

                <div class="kpi-grid mb-3" style="grid-template-columns:repeat(4,1fr)">
                    <div id="" class="card-es kpi green">
                        <div class="icon"><i class="bi bi-cash-stack"></i></div>
                        <div class="label">Total Income</div>
                        
                            <div class="value">
                                ₹ @Convert.ToDecimal(ViewBag.TotalIncome).ToString("N0")
                            
                        </div>
                        <div class="delta">All Time</div>
                    </div>
                
                    <div id="" class="card-es kpi">
                        <div class="icon"><i class="bi bi-calendar-month"></i></div>
                        <div class="label">This Month</div>
                        <div class="value">
                           
                                ₹ @Convert.ToDecimal(ViewBag.ThisMonthIncome).ToString("N0")
                            
                        </div>
                        <div class="delta up">▲ 12% from last month</div>
                    </div>
                    <div id="" class="card-es kpi orange">
                        <div class="icon"><i class="bi bi-wallet2"></i></div>
                        <div class="label">Pending Payments</div>
                        <div class="value">
                            ₹ @Convert.ToDecimal(ViewBag.PendingAmount).ToString("N0")
                        </div>

                        <div class="delta">
                            @ViewBag.PendingCount Pending Invoices
                        </div>
                        <div class="delta">2 Pending Invoices</div>
                    </div>
                    <div id="t" class="card-es kpi purple">
                        <div class="icon"><i class="bi bi-receipt"></i></div>
                        <div class="label">Total Records</div>
                        <div class="value">
                            @ViewBag.TotalRecords
                        </div>
                        <div class="delta">Income Entries</div>
                    </div>
                </div>
                <div class="dash-grid">
                    <div class="card-es">
                        <div class="card-title">Add Income</div>
                        <form class="form-grid" data-toast="Income recorded">

                            <div>
                                <label class="form-label">Source / Client</label>
                                <input id="txtClient" type="text" class="form-control">
                            </div>

                            <div>
                                <label class="form-label">Amount</label>
                                <input id="txtAmount" type="number" class="form-control">
                            </div>

                            <div>
                                <label class="form-label">Date</label>
                                <input id="txtDate" type="date" class="form-control">
                            </div>

                            <div>
                                <label class="form-label">Category</label>
                                <input id="txtCategory" type="text" class="form-control">
                            </div>

                            <div class="full">
                                <label class="form-label">Notes</label>
                                <textarea id="txtNotes" class="form-control"></textarea>
                            </div>

                            <div class="full text-end">
                                <button type="button"
                                        onclick="SaveIncome()"
                                        class="btn btn-primary-grad px-4">
                                    Save Income
                                </button>
                            </div>

                        </form>
                    </div>
                    </div>
                    <div class="card-es mt-4">
                        <table id="tblIncome" class="table-es" data-table data-page-size="6">
                            <thead><tr><th>Invoice</th><th>Client</th><th>Project</th><th>Date</th><th>Amount</th></tr></thead>
                            <tbody>

                                @foreach (var item in Model)
                                {
                                    <tr>

                                        <td>INV-@item.Id</td>

                                        <td>@item.ClientName</td>

                                        <td>@item.Category</td>

                                        <td>
                                            @(item.IncomeDate.HasValue
        ? item.IncomeDate.Value.ToString("dd-MMM-yyyy")
        : "")
                                        </td>

                                        <td>
                                            ₹ @(item.Amount ?? 0)
                                        </td>

                                        <td class="text-end">

                                            <button class="btn-icon">
                                                <i class="bi bi-eye"></i>
                                            </button>

                                            <button class="btn-icon danger">
                                                <i class="bi bi-trash"></i>
                                            </button>

                                        </td>

                                    </tr>
                                }

                            </tbody>
                        </table>
                    </div>




            </section>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Content/assets/js/app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/Content/assets/js/dashboard.js"></script>
    <script src="~/Content/assets/js/table.js"></script>
</body>
</html>



@{
    ViewBag.Title = "ApplicationForm";
    Layout = null;
}
<script src="~/Scripts/jquery-3.7.0.min.js"></script>
<script src="~/Scripts/Application.js"></script>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Application Form · eSankalp Enterprise Portal</title>
    <link rel="icon" href="~/Content/assets/images/esankalp-logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/Content/assets/css/style.css">
    <link rel="stylesheet" href="~/Content/assets/css/dashboard.css">
    <link rel="stylesheet" href="~/Content/assets/css/responsive.css">


</head>
<body>
    <div id="sidebarBackdrop" class="sidebar-backdrop"></div>
    <div class="app">
        <aside class="sidebar scroll-soft">
            <div class="brand">
                <img src="~/Content/assets/images/hero-logo.png" alt="eSankalp">
                <div>
                    <div class="name">eSankalp</div>
                    <div class="tag">Enterprise Portal</div>
                </div>
            </div>
            <div class="section-label">Main</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Dashboard")"><i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span></a>
            <div class="section-label">Manage</div>
            <a class="nav-link-es" href="@Url.Action("Index", "RegistrationList")"><i class="bi bi-people-fill"></i><span>Registration List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationForm")"><i class="bi bi-pencil-square"></i><span>Application Form</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationList")"><i class="bi bi-list-check"></i><span>Application List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientAdd")"><i class="bi bi-person-plus-fill"></i><span>Client Add</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientList")"><i class="bi bi-briefcase-fill"></i><span>Client List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ContactList")"><i class="bi bi-envelope-fill"></i><span>Contact List</span></a>
            <div class="section-label">Finance</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Income")"><i class="bi bi-graph-up-arrow"></i><span>Income</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Expenses")"><i class="bi bi-graph-down-arrow"></i><span>Expenses</span></a>
            <div class="section-label">Content</div>
            <a class="nav-link-es" href="@Url.Action("Index", "AddProduct")"><i class="bi bi-box-seam"></i><span>Add Product</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Portfolio")"><i class="bi bi-images"></i><span>Add Portfolio</span></a>
            <a class="nav-link-es active" href="@Url.Action("Index", "JobApplication")"><i class="bi bi-person-badge"></i><span>Job Application</span></a>
            <div class="mt-auto pt-3">
                <a href="@Url.Action("Logout","Account")"
                   class="btn btn-outline-soft w-100">
                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                </a>
            </div>
        </aside>
        <main class="main">
            <header class="topbar">
                <div class="left">
                    <button id="sidebarToggle" class="icon-btn d-lg-none"><i class="bi bi-list"></i></button>
                    <div>
                        <div class="page-title">Application Form</div>
                        <div class="page-sub">Thinking Beyond Your Imagination</div>
                    </div>
                </div>
                <div class="d-none d-md-flex search hide-mobile">
                    <i class="bi bi-search text-muted"></i>
                    <input type="text" placeholder="Search anything...">
                </div>
                <div class="right">
                    <button class="icon-btn" title="Notifications"><i class="bi bi-bell"></i></button>
                    <button class="icon-btn" title="Settings"><i class="bi bi-gear"></i></button>
                    <div class="avatar" title="Profile"><span id="userName">A</span></div>
                </div>
            </header>
            <section class="content">

                <div class="card-es">
                    <div class="card-title">Application Form</div>
                    <form class="form-grid" data-toast="Application Form saved">
                        <div class=''><label class='form-label'>Full Name</label><input type='text' id="txtName" class='form-control' placeholder='Enter your full name'></div><div class=''><label class='form-label'>Email</label><input type='email' id="txtEmail" class='form-control' placeholder='name@example.com'></div><div class=''><label class='form-label'>Mobile</label><input type='tel' id="txtMobile" class='form-control' placeholder='+91'></div><div class=''><label class='form-label'>Position</label><input type='text' id="txtPosition" class='form-control' placeholder='e.g. Frontend Developer'></div><div>
                            <label class="form-label">Date of Birth</label>
                            <input type="date" id="txtDOB" class="form-control">
                        </div>

                        <div>
                            <label class="form-label">Gender</label>
                            <select id="ddlGender" class="form-control">
                                <option value="">Select Gender</option>
                                <option>Male</option>
                                <option>Female</option>
                                <option>Other</option>
                            </select>
                        </div>

                        <div>
                            <label class="form-label">Skills</label>
                            <input type="text" id="txtSkills" class="form-control" placeholder="ASP.NET, SQL, JavaScript">
                        </div>

                        <div>
                            <label class="form-label">Current City</label>
                            <input type="text" id="txtCity" class="form-control" placeholder="Nagpur">
                        </div><div class='full'><label class='form-label'>Address</label><textarea class='form-control' id="txtAddress" rows='3' placeholder='Street, City, State'></textarea></div><div class=''><label class='form-label'>Education</label><input type='text' id="txtEducation" class='form-control' placeholder='Highest qualification'></div><div class=''><label class='form-label'>Experience</label><input type='text' id="txtExperience" class='form-control' placeholder='e.g. 2 years'></div><div class="full"></div>
                            <div>
                                <label class="form-label">Candidate Photo</label>
                                <input type="file"
                                       class="form-control"
                                       accept=".jpg,.jpeg,.png">
                            </div>

                            <div>
                                <label class="form-label">Resume Upload</label>
                                <input type="file" 
                                       class="form-control"
                                       accept=".pdf,.doc,.docx">
                            </div>
                            <div class="full d-flex gap-2 justify-content-end">
                                <button type="reset" class="btn btn-outline-soft">Reset</button>
                                <button type="button"
                                        onclick="SaveApplication()"
                                        class="btn btn-primary-grad px-4">
                                    Save
                                </button>
                            </div>
                    </form>
                </div>


            </section>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Content/assets/js/app.js"></script>


</body>
</html>



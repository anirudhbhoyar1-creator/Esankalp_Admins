
@{
    ViewBag.Title = "JobApplication";
    Layout = null;
}
<script src="~/Scripts/jquery-3.7.0.min.js"></script>
<script src="~/Scripts/JobApplication.js"></script>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Job Application · eSankalp Enterprise Portal</title>
    <link rel="icon" href="~/Content/assets/images/esankalp-logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/Content/assets/css/style.css">
    <link rel="stylesheet" href="~/Content/assets/css/dashboard.css">
    <link rel="stylesheet" href="~/Content/assets/css/responsive.css">

</head>
<body>
    <div id="sidebarBackdrop" class="sidebar-backdrop"></div>
    <div class="app">
        <aside class="sidebar scroll-soft">
            <div class="brand">
                <img src="~/Content/assets/images/hero-logo.png" alt="eSankalp">
                <div>
                    <div class="name">eSankalp</div>
                    <div class="tag">Enterprise Portal</div>
                </div>
            </div>
            <div class="section-label">Main</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Dashboard")"><i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span></a>
            <div class="section-label">Manage</div>
            <a class="nav-link-es" href="@Url.Action("Index", "RegistrationList")"><i class="bi bi-people-fill"></i><span>Registration List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationForm")"><i class="bi bi-pencil-square"></i><span>Application Form</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationList")"><i class="bi bi-list-check"></i><span>Application List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientAdd")"><i class="bi bi-person-plus-fill"></i><span>Client Add</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientList")"><i class="bi bi-briefcase-fill"></i><span>Client List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ContactList")"><i class="bi bi-envelope-fill"></i><span>Contact List</span></a>
            <div class="section-label">Finance</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Income")"><i class="bi bi-graph-up-arrow"></i><span>Income</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Expenses")"><i class="bi bi-graph-down-arrow"></i><span>Expenses</span></a>
            <div class="section-label">Content</div>
            <a class="nav-link-es" href="@Url.Action("Index", "AddProduct")"><i class="bi bi-box-seam"></i><span>Add Product</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Portfolio")"><i class="bi bi-images"></i><span>Add Portfolio</span></a>
            <a class="nav-link-es active" href="@Url.Action("Index", "JobApplication")"><i class="bi bi-person-badge"></i><span>Job Application</span></a>
            <div class="mt-auto pt-3">
                <a href="@Url.Action("Logout","Account")"
                   class="btn btn-outline-soft w-100">
                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                </a>
            </div>
        </aside>
        <main class="main">
            <header class="topbar">
                <div class="left">
                    <button id="sidebarToggle" class="icon-btn d-lg-none"><i class="bi bi-list"></i></button>
                    <div>
                        <div class="page-title">Job Application</div>
                        <div class="page-sub">Thinking Beyond Your Imagination</div>
                    </div>
                </div>
                <div class="d-none d-md-flex search hide-mobile">
                    <i class="bi bi-search text-muted"></i>
                    <input type="text" placeholder="Search anything...">
                </div>
                <div class="right">
                    <button class="icon-btn" title="Notifications"><i class="bi bi-bell"></i></button>
                    <button class="icon-btn" title="Settings"><i class="bi bi-gear"></i></button>
                    <div class="avatar" title="Profile"><span id="userName">A</span></div>
                </div>
            </header>
            <section class="content">

                <div class="dash-grid">
                    <div class="card-es">
                        <div class="card-title">New Job Application</div>
                        <form class="form-grid" data-toast="Application saved">
                            <div><label class="form-label">Candidate Name</label><input  id="txtCandidateName" class="form-control" placeholder="Full name"></div>
                            <div><label class="form-label">Email</label><input type="email"  id="txtEmail" class="form-control" placeholder="name@example.com"></div>
                            <div><label class="form-label">Mobile</label><input type="tel" id="txtMobile" class="form-control" placeholder="+91"></div>
                            <div>
                                <label class="form-label">Position Applied For</label>
                                <select id="txtPosition" class="form-select"><option>React Developer</option><option>Node.js Engineer</option><option>UI Designer</option><option>QA Engineer</option><option>DevOps</option></select>
                            </div>
                            <div>
                                <label class="form-label">Status</label>
                                <select id="ddlStatus" class="form-select"><option>Pending</option><option>Scheduled</option><option>Selected</option><option>Rejected</option></select>
                            </div>
                            <div><label class="form-label">Interview Date</label><input id="txtInterviewDate" type="date" class="form-control"></div>
                            <div class="full"><label class="form-label">Resume Upload</label><input type="file" class="form-control"></div>
                            <div class="full text-end"><button type="button"
        onclick="SaveJobApplication()"
        class="btn btn-primary-grad">
    Save
</button></div>
                        </form>
                    </div>
                    <div class="card-es">
                        <div class="card-title">Hiring Overview</div>
                        <div class="kpi mb-3"><div class="label">Open Roles</div><div class="value">7</div></div>
                        <div class="kpi orange mb-3"><div class="label">Interviews This Week</div><div class="value">12</div></div>
                        <div class="kpi green"><div class="label">Selected</div><div class="value">3</div></div>
                    </div>
                </div>
                <div class="card-es mt-3">
                    <div class="card-title">Applications</div>
                    <div class="toolbar">
                        <div class="filters">
                            <div class="search" style="background:rgba(255,255,255,.05);border:1px solid var(--es-border);border-radius:10px;padding:6px 10px;min-width:240px">
                                <i class="bi bi-search me-2 text-muted"></i>
                                <input type="text" placeholder="Search candidates..." data-search style="background:transparent;border:0;color:#fff;outline:none">
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-soft btn-sm" data-export="csv"><i class="bi bi-file-earmark-excel me-1"></i> Excel</button>
                        </div>
                    </div>
                    <div class="table-wrap scroll-soft">
                        <table class="table-es" data-table data-page-size="6">
                            <thead><tr><th>ID</th><th>Candidate</th><th>Email</th><th>Mobile</th><th>Position</th><th>Interview</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
                            <tbody id="tblJobApplication">
                                <tr><td>JOB-001</td><td>Aditi Sharma</td><td>aditi@example.com</td><td>+91 99000 11122</td><td>React Developer</td><td>2025-10-05</td><td><span class="badge-es badge-info">Scheduled</span></td><td class="text-end"><button class="btn-icon"><i class="bi bi-eye"></i></button><button class="btn-icon danger" data-row-delete><i class="bi bi-trash"></i></button></td></tr>
                                <tr><td>JOB-002</td><td>Vikram Patel</td><td>vikram@example.com</td><td>+91 98000 22233</td><td>Node.js Engineer</td><td>2025-10-06</td><td><span class="badge-es badge-warning">Pending</span></td><td class="text-end"><button class="btn-icon"><i class="bi bi-eye"></i></button><button class="btn-icon danger" data-row-delete><i class="bi bi-trash"></i></button></td></tr>
                                <tr><td>JOB-003</td><td>Ritika Shah</td><td>ritika@example.com</td><td>+91 97000 33344</td><td>UI Designer</td><td>2025-10-07</td><td><span class="badge-es badge-success">Selected</span></td><td class="text-end"><button class="btn-icon"><i class="bi bi-eye"></i></button><button class="btn-icon danger" data-row-delete><i class="bi bi-trash"></i></button></td></tr>
                                <tr><td>JOB-004</td><td>Manav Kapoor</td><td>manav@example.com</td><td>+91 96000 44455</td><td>QA Engineer</td><td>2025-10-08</td><td><span class="badge-es badge-danger">Rejected</span></td><td class="text-end"><button class="btn-icon"><i class="bi bi-eye"></i></button><button class="btn-icon danger" data-row-delete><i class="bi bi-trash"></i></button></td></tr>
                                <tr><td>JOB-005</td><td>Esha Verma</td><td>esha@example.com</td><td>+91 95000 55566</td><td>DevOps</td><td>2025-10-09</td><td><span class="badge-es badge-info">Scheduled</span></td><td class="text-end"><button class="btn-icon"><i class="bi bi-eye"></i></button><button class="btn-icon danger" data-row-delete><i class="bi bi-trash"></i></button></td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="pagination-es" data-pagination></div>
                </div>

            </section>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Content/assets/js/app.js"></script>
    <script src="~/Content/assets/js/table.js"></script>
</body>
</html>



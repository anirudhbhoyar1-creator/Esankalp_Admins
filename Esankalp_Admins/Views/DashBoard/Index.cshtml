
@{
    ViewBag.Title = "Index";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Dashboard · eSankalp Enterprise Portal</title>
    <link rel="icon" href="~/Content/assets/images/esankalp-logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/Content/assets/css/style.css">
    <link rel="stylesheet" href="~/Content/assets/css/dashboard.css">
    <link rel="stylesheet" href="~/Content/assets/css/responsive.css">

</head>
<body>
    <div id="sidebarBackdrop" class="sidebar-backdrop"></div>
    <div class="app">
        <aside class="sidebar scroll-soft">
            <div class="brand">
                <img src="~/Content/assets/images/hero-logo.png" alt="eSankalp">
                <div>
                    <div class="name">eSankalp</div>
                    <div class="tag">Enterprise Portal</div>
                </div>
            </div>
            <div class="section-label">Main</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Dashboard")"><i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span></a>
            <div class="section-label">Manage</div>
            <a class="nav-link-es" href="@Url.Action("Index", "RegistrationList")"><i class="bi bi-people-fill"></i><span>Registration List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationForm")"><i class="bi bi-pencil-square"></i><span>Application Form</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationList")"><i class="bi bi-list-check"></i><span>Application List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientAdd")"><i class="bi bi-person-plus-fill"></i><span>Client Add</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientList")"><i class="bi bi-briefcase-fill"></i><span>Client List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ContactList")"><i class="bi bi-envelope-fill"></i><span>Contact List</span></a>
            <div class="section-label">Finance</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Income")"><i class="bi bi-graph-up-arrow"></i><span>Income</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Expenses")"><i class="bi bi-graph-down-arrow"></i><span>Expenses</span></a>
            <div class="section-label">Content</div>
            <a class="nav-link-es" href="@Url.Action("Index", "AddProduct")"><i class="bi bi-box-seam"></i><span>Add Product</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Portfolio")"><i class="bi bi-images"></i><span>Add Portfolio</span></a>
            <a class="nav-link-es active" href="@Url.Action("Index", "JobApplication")"><i class="bi bi-person-badge"></i><span>Job Application</span></a>
            <div class="mt-auto pt-3">
                <a href="@Url.Action("Logout","Account")"
                   class="btn btn-outline-soft w-100">
                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                </a>
            </div>
        </aside>
        <main class="main">
            <header class="topbar">
                <div class="left">
                    <button id="sidebarToggle" class="icon-btn d-lg-none"><i class="bi bi-list"></i></button>
                    <div>
                        <div class="page-title">Dashboard</div>
                        <div class="page-sub">Thinking Beyond Your Imagination</div>
                    </div>
                </div>
                <div class="d-none d-md-flex search hide-mobile">
                    <i class="bi bi-search text-muted"></i>
                    <input type="text" placeholder="Search anything...">
                </div>
                <div class="right">
                    <button class="icon-btn" title="Notifications"><i class="bi bi-bell"></i></button>
                    <button class="icon-btn" title="Settings"><i class="bi bi-gear"></i></button>
                    <div class="avatar" title="Profile"><span id="userName">A</span></div>
                </div>
            </header>
            <section class="content">

                <div class="kpi-grid">
                    <div class="card-es kpi"><div class="icon"><i class="bi bi-people-fill"></i></div><div class="label">Total Registrations</div><div class="value">2,438</div><div class="delta up">▲ 12.4% this month</div></div>
                    <div class="card-es kpi orange"><div class="icon"><i class="bi bi-briefcase-fill"></i></div><div class="label">Total Clients</div><div class="value">312</div><div class="delta up">▲ 6.1%</div></div>
                    <div class="card-es kpi green"><div class="icon"><i class="bi bi-rocket-takeoff"></i></div><div class="label">Active Projects</div><div class="value">48</div><div class="delta up">▲ 3 new</div></div>
                    <div class="card-es kpi purple"><div class="icon"><i class="bi bi-person-badge"></i></div><div class="label">Total Interns</div><div class="value">96</div><div class="delta up">▲ 8</div></div>
                    <div class="card-es kpi yellow"><div class="icon"><i class="bi bi-currency-rupee"></i></div><div class="label">Monthly Income</div><div class="value">₹ 1.42L</div><div class="delta up">▲ 9.7%</div></div>
                    <div class="card-es kpi pink"><div class="icon"><i class="bi bi-graph-up"></i></div><div class="label">Monthly Growth</div><div class="value">18.5%</div><div class="delta up">▲ 2.3%</div></div>
                </div>

                <div class="dash-grid">
                    <div class="card-es">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="card-title mb-0">Revenue Overview</div>
                            <div class="badge-es badge-info">Yearly</div>
                        </div>
                        <div class="chart-box"><canvas id="revenueChart"></canvas></div>
                    </div>
                    <div class="card-es">
                        <div class="card-title">Project Categories</div>
                        <div class="chart-box"><canvas id="categoryChart"></canvas></div>
                    </div>
                </div>

                <div class="dash-grid-3">
                    <div class="card-es">
                        <div class="card-title">Recent Registrations</div>
                        <div class="list-item"><div class="row-photo">AR</div><div class="flex-grow-1"><div class="title">Aarav Sharma</div><div class="meta">B.Tech CSE · Pune</div></div><span class="badge-es badge-success">New</span></div>
                        <div class="list-item"><div class="row-photo">PR</div><div class="flex-grow-1"><div class="title">Priya Rao</div><div class="meta">MCA · Bangalore</div></div><span class="badge-es badge-info">Verified</span></div>
                        <div class="list-item"><div class="row-photo">KM</div><div class="flex-grow-1"><div class="title">Karan Mehta</div><div class="meta">BCA · Mumbai</div></div><span class="badge-es badge-warning">Pending</span></div>
                        <div class="list-item"><div class="row-photo">SN</div><div class="flex-grow-1"><div class="title">Sneha Nair</div><div class="meta">M.Tech · Chennai</div></div><span class="badge-es badge-success">New</span></div>
                    </div>
                    <div class="card-es">
                        <div class="card-title">Recent Applications</div>
                        <div class="list-item"><div class="row-photo">RK</div><div class="flex-grow-1"><div class="title">Frontend Intern</div><div class="meta">Rohit K · 2h ago</div></div><span class="badge-es badge-info">Review</span></div>
                        <div class="list-item"><div class="row-photo">DV</div><div class="flex-grow-1"><div class="title">UI Designer</div><div class="meta">Devika V · 5h ago</div></div><span class="badge-es badge-success">Shortlisted</span></div>
                        <div class="list-item"><div class="row-photo">AY</div><div class="flex-grow-1"><div class="title">Backend Engg</div><div class="meta">Ayan Y · 1d ago</div></div><span class="badge-es badge-warning">Pending</span></div>
                        <div class="list-item"><div class="row-photo">TS</div><div class="flex-grow-1"><div class="title">Data Analyst</div><div class="meta">Tanya S · 2d ago</div></div><span class="badge-es badge-danger">Rejected</span></div>
                    </div>
                    <div class="card-es">
                        <div class="card-title">Quick Actions</div>
                        <div class="qa-grid">
                            <a class="qa" href="client-add.html"><i class="bi bi-person-plus-fill"></i> Add Client</a>
                            <a class="qa" href="add-product.html"><i class="bi bi-box-seam"></i> Add Product</a>
                            <a class="qa" href="add-portfolio.html"><i class="bi bi-images"></i> Add Portfolio</a>
                            <a class="qa" href="income.html"><i class="bi bi-currency-rupee"></i> Add Income</a>
                            <a class="qa" href="expenses.html"><i class="bi bi-cash-stack"></i> Add Expense</a>
                            <a class="qa" href="job-application.html"><i class="bi bi-person-badge"></i> Jobs</a>
                        </div>
                    </div>
                </div>

                <div class="dash-grid-3">
                    <div class="card-es">
                        <div class="card-title">Weekly Traffic</div>
                        <div class="chart-box"><canvas id="trafficChart"></canvas></div>
                    </div>
                    <div class="card-es">
                        <div class="card-title">Activity Timeline</div>
                        <div class="timeline">
                            <div class="t-item"><div class="t-title">New client onboarded</div><div class="t-meta">Acme Corp · 10 min ago</div></div>
                            <div class="t-item"><div class="t-title">Invoice paid</div><div class="t-meta">₹48,000 · 1 hour ago</div></div>
                            <div class="t-item"><div class="t-title">Job application received</div><div class="t-meta">React Developer · 3h ago</div></div>
                            <div class="t-item"><div class="t-title">Portfolio updated</div><div class="t-meta">Project "Lumen" · Yesterday</div></div>
                        </div>
                    </div>
                    <div class="card-es">
                        <div class="card-title">Notifications</div>
                        <div class="notif"><i class="bi bi-bell-fill text-warning me-2"></i> 3 new registrations pending approval.</div>
                        <div class="notif"><i class="bi bi-check-circle-fill text-success me-2"></i> Backup completed successfully.</div>
                        <div class="notif"><i class="bi bi-exclamation-triangle-fill text-danger me-2"></i> Server CPU usage above 80%.</div>
                        <div class="notif"><i class="bi bi-info-circle-fill text-info me-2"></i> New version v2.1 available.</div>
                    </div>
                </div>

            </section>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Content/assets/js/app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/Content/assets/js/dashboard.js"></script>
</body>
</html>


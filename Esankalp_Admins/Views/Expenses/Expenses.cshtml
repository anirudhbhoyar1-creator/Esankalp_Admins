
@{
    ViewBag.Title = "Expenses";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Expenses · eSankalp Enterprise Portal</title>
    <link rel="icon" href="~/Content/assets/images/esankalp-logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/Content/assets/css/style.css">
    <link rel="stylesheet" href="~/Content/assets/css/dashboard.css">
    <link rel="stylesheet" href="~/Content/assets/css/responsive.css">

</head>
<body>
    <div id="sidebarBackdrop" class="sidebar-backdrop"></div>
    <div class="app">
        <aside class="sidebar scroll-soft">
            <div class="brand">
                <img src="~/Content/assets/images/hero-logo.png" alt="eSankalp">
                <div>
                    <div class="name">eSankalp</div>
                    <div class="tag">Enterprise Portal</div>
                </div>
            </div>
            <div class="section-label">Main</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Dashboard")"><i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span></a>
            <div class="section-label">Manage</div>
            <a class="nav-link-es" href="@Url.Action("Index", "RegistrationList")"><i class="bi bi-people-fill"></i><span>Registration List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationForm")"><i class="bi bi-pencil-square"></i><span>Application Form</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationList")"><i class="bi bi-list-check"></i><span>Application List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientAdd")"><i class="bi bi-person-plus-fill"></i><span>Client Add</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientList")"><i class="bi bi-briefcase-fill"></i><span>Client List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ContactList")"><i class="bi bi-envelope-fill"></i><span>Contact List</span></a>
            <div class="section-label">Finance</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Income")"><i class="bi bi-graph-up-arrow"></i><span>Income</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Expenses")"><i class="bi bi-graph-down-arrow"></i><span>Expenses</span></a>
            <div class="section-label">Content</div>
            <a class="nav-link-es" href="@Url.Action("Index", "AddProduct")"><i class="bi bi-box-seam"></i><span>Add Product</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Portfolio")"><i class="bi bi-images"></i><span>Add Portfolio</span></a>
            <a class="nav-link-es active" href="@Url.Action("Index", "JobApplication")"><i class="bi bi-person-badge"></i><span>Job Application</span></a>
            <div class="mt-auto pt-3">
                <a href="@Url.Action("Logout","Account")"
                   class="btn btn-outline-soft w-100">
                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                </a>
            </div>
        </aside>
        <main class="main">
            <header class="topbar">
                <div class="left">
                    <button id="sidebarToggle" class="icon-btn d-lg-none"><i class="bi bi-list"></i></button>
                    <div>
                        <div class="page-title">Expenses</div>
                        <div class="page-sub">Thinking Beyond Your Imagination</div>
                    </div>
                </div>
                <div class="d-none d-md-flex search hide-mobile">
                    <i class="bi bi-search text-muted"></i>
                    <input type="text" placeholder="Search anything...">
                </div>
                <div class="right">
                    <button class="icon-btn" title="Notifications"><i class="bi bi-bell"></i></button>
                    <button class="icon-btn" title="Settings"><i class="bi bi-gear"></i></button>
                    <div class="avatar" title="Profile"><span id="userName">A</span></div>
                </div>
            </header>
            <section class="content">

                <div class="kpi-grid mb-3" style="grid-template-columns:repeat(4,1fr)">
                    <div class="card-es kpi orange"><div class="icon"><i class="bi bi-cash-stack"></i></div><div class="label">This Month</div><div class="value">₹ 6.25L</div><div class="delta down">▲ 4%</div></div>
                    <div class="card-es kpi"><div class="icon"><i class="bi bi-clock"></i></div><div class="label">Pending</div><div class="value">₹ 35,000</div><div class="delta">1 bill</div></div>
                    <div class="card-es kpi green"><div class="icon"><i class="bi bi-piggy-bank"></i></div><div class="label">Net Savings</div><div class="value">₹ 1.42L</div><div class="delta up">▲ 6%</div></div>
                    <div class="card-es kpi purple"><div class="icon"><i class="bi bi-bar-chart"></i></div><div class="label">Top Category</div><div class="value">Payroll</div><div class="delta">76%</div></div>
                </div>
                <div class="dash-grid">
                    <div class="card-es">
                        <div class="card-title">Add Expense</div>
                        <form class="form-grid" data-toast="Expense recorded">
                            <div><label class="form-label">Title</label><input type="text" class="form-control" placeholder="Expense title"></div>
                            <div><label class="form-label">Amount</label><input type="number" class="form-control" placeholder="0.00"></div>
                            <div><label class="form-label">Date</label><input type="date" class="form-control"></div>
                            <div>
                                <label class="form-label">Category</label>
                                <select class="form-select"><option>Operations</option><option>Payroll</option><option>Infrastructure</option><option>Marketing</option><option>Tools</option></select>
                            </div>
                            <div class="full"><label class="form-label">Notes</label><textarea class="form-control" rows="2"></textarea></div>
                            <div class="full text-end"><button class="btn btn-primary-grad px-4" style="width:auto">Save Expense</button></div>
                        </form>
                    </div>
                    <div class="card-es">
                        <div class="card-title">Weekly Expenses</div>
                        <div class="chart-box"><canvas id="expenseChart"></canvas></div>
                    </div>
                </div>

                <div class="card-es mt-3">
                    <div class="toolbar">
                        <div class="filters">
                            <div class="search" style="background:rgba(255,255,255,.05);border:1px solid var(--es-border);border-radius:10px;padding:6px 10px;min-width:240px">
                                <i class="bi bi-search me-2 text-muted"></i>
                                <input type="text" placeholder="Search expenses..." data-search style="background:transparent;border:0;color:#fff;outline:none">
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-soft btn-sm" data-export="csv"><i class="bi bi-file-earmark-excel me-1"></i> Excel</button>
                        </div>
                    </div>
                    <div class="table-wrap scroll-soft">
                        <table class="table-es" data-table data-page-size="6">
                            <thead><tr><th>ID</th><th>Title</th><th>Category</th><th>Date</th><th>Amount</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
                            <tbody>
                                <tr><td>EXP-3001</td><td>Office Rent</td><td>Operations</td><td>2025-09-01</td><td>₹ 60,000</td><td><span class="badge-es badge-success">Paid</span></td><td class="text-end"><button class="btn-icon"><i class="bi bi-eye"></i></button><button class="btn-icon danger" data-row-delete><i class="bi bi-trash"></i></button></td></tr>
                                <tr><td>EXP-3002</td><td>AWS Cloud</td><td>Infrastructure</td><td>2025-09-04</td><td>₹ 28,400</td><td><span class="badge-es badge-success">Paid</span></td><td class="text-end"><button class="btn-icon"><i class="bi bi-eye"></i></button><button class="btn-icon danger" data-row-delete><i class="bi bi-trash"></i></button></td></tr>
                                <tr><td>EXP-3003</td><td>Salaries</td><td>Payroll</td><td>2025-09-05</td><td>₹ 4,80,000</td><td><span class="badge-es badge-success">Paid</span></td><td class="text-end"><button class="btn-icon"><i class="bi bi-eye"></i></button><button class="btn-icon danger" data-row-delete><i class="bi bi-trash"></i></button></td></tr>
                                <tr><td>EXP-3004</td><td>Marketing</td><td>Growth</td><td>2025-09-12</td><td>₹ 35,000</td><td><span class="badge-es badge-warning">Pending</span></td><td class="text-end"><button class="btn-icon"><i class="bi bi-eye"></i></button><button class="btn-icon danger" data-row-delete><i class="bi bi-trash"></i></button></td></tr>
                                <tr><td>EXP-3005</td><td>Software Licenses</td><td>Tools</td><td>2025-09-18</td><td>₹ 22,000</td><td><span class="badge-es badge-success">Paid</span></td><td class="text-end"><button class="btn-icon"><i class="bi bi-eye"></i></button><button class="btn-icon danger" data-row-delete><i class="bi bi-trash"></i></button></td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="pagination-es" data-pagination></div>
                </div>

            </section>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Content/assets/js/app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/Content/assets/js/dashboard.js"></script>
    <script src="~/Content/assets/js/table.js"></script>
</body>
</html>



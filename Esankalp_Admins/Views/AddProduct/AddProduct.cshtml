@model List<RegistrationList.Data.ProductMaster>
@{
    ViewBag.Title = "AddProduct";
    Layout = null;
}
<script src="~/Scripts/jquery-3.7.0.min.js"></script>
<script src="~/Scripts/Product.js"></script>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Add Product · eSankalp Enterprise Portal</title>
    <link rel="icon" href="~/Content/assets/images/esankalp-logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/Content/assets/css/style.css">
    <link rel="stylesheet" href="~/Content/assets/css/dashboard.css">
    <link rel="stylesheet" href="~/Content/assets/css/responsive.css">

</head>
<body>
    <div id="sidebarBackdrop" class="sidebar-backdrop"></div>
    <div class="app">
        <aside class="sidebar scroll-soft">
            <div class="brand">
                <img src="~/Content/assets/images/hero-logo.png" alt="eSankalp">
                <div>
                    <div class="name">eSankalp</div>
                    <div class="tag">Enterprise Portal</div>
                </div>
            </div>
            <div class="section-label">Main</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Dashboard")"><i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span></a>
            <div class="section-label">Manage</div>
            <a class="nav-link-es" href="@Url.Action("Index", "RegistrationList")"><i class="bi bi-people-fill"></i><span>Registration List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationForm")"><i class="bi bi-pencil-square"></i><span>Application Form</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ApplicationList")"><i class="bi bi-list-check"></i><span>Application List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientAdd")"><i class="bi bi-person-plus-fill"></i><span>Client Add</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ClientList")"><i class="bi bi-briefcase-fill"></i><span>Client List</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "ContactList")"><i class="bi bi-envelope-fill"></i><span>Contact List</span></a>
            <div class="section-label">Finance</div>
            <a class="nav-link-es" href="@Url.Action("Index", "Income")"><i class="bi bi-graph-up-arrow"></i><span>Income</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Expenses")"><i class="bi bi-graph-down-arrow"></i><span>Expenses</span></a>
            <div class="section-label">Content</div>
            <a class="nav-link-es" href="@Url.Action("Index", "AddProduct")"><i class="bi bi-box-seam"></i><span>Add Product</span></a>
            <a class="nav-link-es" href="@Url.Action("Index", "Portfolio")"><i class="bi bi-images"></i><span>Add Portfolio</span></a>
            <a class="nav-link-es active" href="@Url.Action("Index", "JobApplication")"><i class="bi bi-person-badge"></i><span>Job Application</span></a>
            <div class="mt-auto pt-3">
                <a href="@Url.Action("Logout","Account")"
                   class="btn btn-outline-soft w-100">
                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                </a>
            </div>
        </aside>
        <main class="main">
            <header class="topbar">
                <div class="left">
                    <button id="sidebarToggle" class="icon-btn d-lg-none"><i class="bi bi-list"></i></button>
                    <div>
                        <div class="page-title">Add Product</div>
                        <div class="page-sub">Thinking Beyond Your Imagination</div>
                    </div>
                </div>
                <div class="d-none d-md-flex search hide-mobile">
                    <i class="bi bi-search text-muted"></i>
                    <input type="text" placeholder="Search anything...">
                </div>
                <div class="right">
                    <button class="icon-btn" title="Notifications"><i class="bi bi-bell"></i></button>
                    <button class="icon-btn" title="Settings"><i class="bi bi-gear"></i></button>
                    <div class="avatar" title="Profile"><span id="userName">A</span></div>
                </div>
            </header>
            <section class="content">

                <div class="dash-grid">
                    <div class="card-es">
                        <div class="card-title">Add Product</div>
                        <form class="form-grid" data-toast="Product saved">
                            <div><label class="form-label">Product Name</label><input id="txtProductName" class="form-control" placeholder="Name"></div>
                            <div>
                                <label class="form-label">Category</label>
                                <select id="ddlCategory" class="form-select"><option>SaaS</option><option>Education</option><option>FinTech</option><option>E-commerce</option></select>
                            </div>
                            <div><label class="form-label">Price (₹)</label><input id="txtPrice" type="number" class="form-control" placeholder="0.00"></div>
                            <div>
                                <label class="form-label">Status</label>
                                <select id="ddlStatus" class="form-select"><option>Live</option><option>Beta</option><option>Draft</option></select>
                            </div>
                            <div class="full"><label class="form-label">Description</label><textarea id="txtDescription" class="form-control" rows="3"></textarea></div>
                            <div class="full"><label class="form-label">Image Upload</label><input type="file" class="form-control"></div>
                            <div class="full text-end">
                                <button type="button"
                                        onclick="SaveProduct()"
                                        class="btn btn-primary-grad">
                                    Save Product
                                </button>
                            </div>
                        </form>
                    </div>
                    <div class="card-es">
                        <div class="card-title">Tips</div>
                        <ul class="text-muted small">
                            <li>Use clear, scannable product names.</li>
                            <li>Upload square images at least 800×800 for best results.</li>
                            <li>Keep descriptions under 200 characters.</li>
                            <li>Mark "Draft" while you're still iterating.</li>
                        </ul>
                    </div>
                </div>
                <div class="card-es mt-3">
                    <div class="card-title">Existing Products</div>
                    <div class="table-wrap scroll-soft">
                        <table class="table-es" data-table data-page-size="6">
                            <thead><tr><th>ID</th><th>Name</th><th>Category</th><th>Price</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
                            <tbody>

                                @foreach (var item in Model)
                                {
                                    <tr>

                                        <td>@item.Id</td>

                                        <td>@item.ProductName</td>

                                        <td>@item.Category</td>

                                        <td>₹ @item.Price</td>

                                        <td>@item.Status</td>

                                        <td>

                                            <button class="btn-icon">
                                                <i class="bi bi-eye"></i>
                                            </button>

                                            <button class="btn-icon danger">
                                                <i class="bi bi-trash"></i>
                                            </button>

                                        </td>

                                    </tr>
                                }

                            </tbody>
                        </table>
                    </div>
                    <div class="pagination-es" data-pagination></div>
                </div>

            </section>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Content/assets/js/app.js"></script>
    <script src="~/Content/assets/js/table.js"></script>
</body>
</html>
